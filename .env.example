# Database - Get free PostgreSQL from https://railway.app
DATABASE_URL=postgresql://user:password@host:5432/agriconnect

# JWT Secret - Generate a random string
JWT_SECRET=your-super-secret-jwt-key-change-this

# Server
PORT=3000
NODE_ENV=development

# Africa's Talking SMS (for real OTP)
# Get free account at https://africastalking.com
AT_API_KEY=your-africastalking-api-key
AT_USERNAME=sandbox

# Paystack (for Mobile Money payments)
# Get free account at https://paystack.com
PAYSTACK_SECRET_KEY=sk_test_your-paystack-key
